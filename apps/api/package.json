{
  "name": "@petready/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run --dir src",
    "test:integration": "vitest run --dir tests",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:rollback": "tsx src/db/rollback.ts"
  },
  "dependencies": {
    "@petready/shared": "workspace:*",
    "bcryptjs": "2.4.3",
    "bull": "4.16.3",
    "cors": "2.8.5",
    "express": "4.21.0",
    "helmet": "7.1.0",
    "jsonwebtoken": "9.0.2",
    "morgan": "1.10.0",
    "pg": "8.13.0",
    "resend": "3.5.0",
    "web-push": "3.6.7",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/jsonwebtoken": "9.0.7",
    "@types/morgan": "1.9.9",
    "@types/node": "22.7.4",
    "@types/pg": "8.11.10",
    "@types/web-push": "3.6.3",
    "eslint": "8.57.0",
    "supertest": "7.0.0",
    "tsx": "4.19.1",
    "typescript": "5.5.4",
    "vitest": "1.6.0"
  }
}
