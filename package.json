{
  "name": "petready",
  "version": "0.1.0",
  "private": true,
  "description": "Pet ownership readiness platform",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "typecheck": "turbo typecheck",
    "test:unit": "turbo test:unit",
    "test:integration": "turbo test:integration",
    "test:e2e": "turbo test:e2e",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "prettier": "3.3.3",
    "turbo": "2.1.3",
    "typescript": "5.5.4",
    "vitest": "1.6.0"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  }
}
